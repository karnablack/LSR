# Frontend (Vite) configuration — optional.
# Copy to `.env` only if the backend is NOT on the same machine as the browser.
#
# Where the dashboard should reach the LSR backend API.
# Local dev (default, no file needed):  http://127.0.0.1:8000
# Remote VM / production:               your backend's public URL
# VITE_API_BASE=https://lsr.example.com
