# =============================================================================
# LSR Synaptic Response Center — environment template
# Copy to `.env` and fill in. NEVER commit the real .env (it is git-ignored).
# Every value is optional: with no .env, LSR runs in deterministic OFFLINE mode.
# =============================================================================

# --- Runtime -----------------------------------------------------------------
LSR_ENVIRONMENT=development
LSR_LOG_LEVEL=INFO

# Comma-separated list of browser origins allowed to call the API (CORS).
# Default already trusts the local Vite dev server.
LSR_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional API key. Leave EMPTY for open demo mode (no auth — judges/users can
# run with zero config). When set, state-changing endpoints (/webhook/alerts,
# /api/demo/trigger, /api/incident/escalate, /api/incident/resolve,
# /api/copilot/chat) require it as `Authorization: Bearer <key>` or `X-API-Key`.
# Recommended for any shared/corporate deployment.
LSR_API_KEY=

# Public URL of the dashboard (used in Teams/Slack "Open Dashboard" buttons).
LSR_DASHBOARD_URL=http://localhost:5173

# --- AI model (vendor-neutral, OpenAI-compatible) ----------------------------
# provider: disabled | openai | azure
#   disabled → no external calls, deterministic reasoning (default, great for demos)
#   openai   → OpenAI OR any OpenAI-compatible endpoint (set LSR_LLM_BASE_URL)
#   azure    → Azure OpenAI / Azure AI Foundry
LSR_LLM_PROVIDER=disabled
LSR_LLM_API_KEY=
# Model or deployment name — always your choice; check your provider's catalog.
LSR_LLM_MODEL=
LSR_LLM_TEMPERATURE=0.1

# For Azure OpenAI / Azure AI Foundry:
#   LSR_LLM_PROVIDER=azure
#   LSR_LLM_BASE_URL=https://<your-resource>.openai.azure.com
#   LSR_LLM_API_VERSION=<see your Azure deployment docs>
#   LSR_LLM_MODEL=<your-deployment-name>
#
# For a local model (Ollama / LM Studio / vLLM), OpenAI-compatible:
#   LSR_LLM_PROVIDER=openai
#   LSR_LLM_BASE_URL=http://localhost:<runtime-port>/v1
#   LSR_LLM_MODEL=<your-local-model-name>
LSR_LLM_BASE_URL=
LSR_LLM_API_VERSION=

# --- Notifications (optional) ------------------------------------------------
# Microsoft Teams incoming webhook (Workflows). Receives Adaptive Cards.
LSR_TEAMS_WEBHOOK_URL=
# Slack incoming webhook.
LSR_SLACK_WEBHOOK_URL=
# Optional public image URL shown in the SLA-breach escalation follow-up.
LSR_ESCALATION_IMAGE_URL=

# --- Policy ------------------------------------------------------------------
LSR_AUTO_REMEDIATION=true
LSR_SLA_BREACH_SECONDS=30
